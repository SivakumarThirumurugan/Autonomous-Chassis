<?xml version="1.0"?>
<robot name="differential_drive_chassis">

  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="bright_red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/base_link.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <link name="fl_knuckle">
    <visual>
      <origin xyz="-0.1555 -0.12284 -0.01597" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/fl_knuckle.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <joint name="fl_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fl_knuckle"/>
    <origin xyz="0.1555 0.12284 0.01597" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <limit lower="-0.52" upper="0.52" effort="10.0" velocity="5.0"/>
  </joint>

<link name="fl_wheel">
    <visual>
      <origin xyz="-0.1555 -0.15284 -0.01597" rpy="0 0 0"/> 
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/fl_wheel.stl"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/> <geometry>
        <cylinder radius="0.06" length="0.04"/> </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="fl_wheel_joint" type="continuous">
    <parent link="fl_knuckle"/>
    <child link="fl_wheel"/>
    <origin xyz="0.0 0.030 0.0" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/> </joint>
  <link name="fr_knuckle">
    <visual>
      <origin xyz="-0.1555 0.12284 -0.01597" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/fr_knuckle.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <joint name="fr_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fr_knuckle"/>
    <origin xyz="0.1555 -0.12284 0.01597" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.52" upper="0.52" effort="10.0" velocity="5.0"/>
  </joint>

  <link name="fr_wheel">
    <visual>
      <origin xyz="-0.1595 0.13534 -0.01597" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/fr_wheel.stl"/>
      </geometry>
      <material name="bright_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="fr_wheel_joint" type="continuous">
    <parent link="fr_knuckle"/>
    <child link="fr_wheel"/>
    <origin xyz="0.004 -0.0125 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rl_wheel">
    <visual>
      <origin xyz="0.1555 -0.10784 -0.00347" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/rl_wheel.stl"/>
      </geometry>
      <material name="bright_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="rl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rl_wheel"/>
    <origin xyz="-0.1555 0.10784 0.00347" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rr_wheel">
    <visual>
      <origin xyz="0.1555 0.10784 -0.00347" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://autonomous_chassis_description/meshes/rr_wheel.stl"/>
      </geometry>
      <material name="bright_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="rr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rr_wheel"/>
    <origin xyz="-0.1555 -0.10784 0.00347" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
