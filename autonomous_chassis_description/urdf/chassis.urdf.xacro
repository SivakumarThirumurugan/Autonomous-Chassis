<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="autonomous_chassis">

  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_length" value="0.04"/>
  <xacro:property name="wheel_mass"   value="1.0"/>

  <xacro:macro name="wheel_assembly" params="prefix reflect_x reflect_y">
    
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_knuckle"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0.004 ${0.0125 * reflect_y} 0.0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="-0.1595 ${-0.13534 * reflect_y} -0.01597" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://autonomous_chassis_description/meshes/${prefix}_wheel.stl"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:wheel_assembly prefix="fl" reflect_x="1"  reflect_y="1" />
  <xacro:wheel_assembly prefix="fr" reflect_x="1"  reflect_y="-1"/>

</robot>
